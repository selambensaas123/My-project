<ui:UXML xmlns:ui="UnityEngine.UIElements" xmlns:uie="UnityEditor.UIElements" xsi="http://www.w3.org/2001/XMLSchema-instance" engine="UnityEngine.UIElements" editor="UnityEditor.UIElements" noNamespaceSchemaLocation="../../../../../../UIElementsSchema/UIElements.xsd" editor-extension-mode="False">
    <Style src="project://database/Assets/One%20Tap%20UI/UI/UI%20Toolkit/StyleSheets/Theme.uss?fileID=7433441132597879392&amp;guid=b9a98c74e86540ac9e794dfc5a785ed8&amp;type=3#Theme" />
    <ui:VisualElement name="Bottom" style="flex-direction: row; align-items: flex-end; flex-wrap: nowrap; height: auto; min-height: auto; max-height: none; justify-content: space-between; padding-top: 0;">
        <ui:Button display-tooltip-when-elided="true" name="Back" enable-rich-text="false" class="button" style="height: 110px; position: relative; left: auto; top: auto; width: 110px; right: 0; bottom: 0; font-size: 60px; opacity: 1; margin-top: 0; margin-bottom: 0; margin-left: 0; margin-right: 0; flex-direction: row; min-height: auto; padding-left: 15px; padding-right: 15px; padding-top: 15px; padding-bottom: 15px;">
            <ui:VisualElement name="Icon" class="back-button" style="width: 100%; height: 100%;" />
        </ui:Button>
        <ui:Button text="Apply" display-tooltip-when-elided="true" name="Apply" class="button" style="height: 110px; position: relative; left: auto; top: auto; width: 230px; right: 0; bottom: 0; font-size: 60px; opacity: 1; margin-top: 0; margin-bottom: 0; margin-left: 0; margin-right: 0; flex-direction: row; min-height: auto;" />
    </ui:VisualElement>
</ui:UXML>
