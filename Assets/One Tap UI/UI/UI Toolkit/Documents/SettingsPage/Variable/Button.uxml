    <ui:VisualElement name="Button" class="base-field variable" style="flex-direction: row; justify-content: space-between; width: auto; -unity-text-align: middle-left; align-items: center; padding-left: 15px; padding-right: 15px; padding-top: 15px; padding-bottom: 15px; height: 100px;">
